{
  "borders": {
    "mobile": {
      "card-border-radius-xs": {
        "$type": "dimension",
        "$value": "0px"
      },
      "card-border-width-xs": {
        "$type": "dimension",
        "$value": "0px"
      }
    },
    "desktop": {
      "radius": {
        "card-border-radius-lg": {
          "$type": "dimension",
          "$value": "0px"
        },
        "card-thumbnail-border-radius-lg": {
          "$type": "dimension",
          "$value": "50px"
        },
        "card-thumbnail-border-radius-alt-lg": {
          "$type": "dimension",
          "$value": "0px"
        }
      },
      "width": {
        "card-border-width-lg": {
          "$type": "dimension",
          "$value": "{border-width.desktop.border-width-regular-lg}"
        },
        "card-border-width-alt-lg": {
          "$type": "dimension",
          "$value": "{border-width.desktop.border-width-thick-lg}"
        }
      }
    }
  },
  "notes-card-border-radius": {
    "$type": "string",
    "$value": "border is on the image not the card"
  },
  "notes-card-thumbnail-border-width": {
    "$type": "string",
    "$value": "mixed border-width: sm sm lg sm"
  },
  "card-border-color": {
    "$type": "color",
    "$value": "{color.transparent}"
  },
  "notes-card-thumbnail-border-radius-2": {
    "$type": "string",
    "$value": "mixed border-radius: px 0 px 0"
  }
}